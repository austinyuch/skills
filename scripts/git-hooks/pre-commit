#!/bin/bash
# DevSecOps pre-commit hook for aclab/skills
# Purpose: FAST, staged-only guardrails for this Agent Skills collection.
#
# Checks (each prints PASS / FAIL; all run, then we exit non-zero if any failed):
#   1. secret scan         - hardcoded keys/tokens/private-keys in added lines
#   2. absolute-path scan  - machine-specific /home/<user>/... paths in skills/**
#   3. purged-skill denylist - block re-introducing Anthropic/Giant-derived skills
#   4. JSON validity       - skills-manifest.json (+ any staged *.json) parse
#   5. conflict markers    - no leftover <<<<<<< / ======= / >>>>>>> markers
#   6. shell syntax        - bash -n on changed *.sh / hook scripts
#   7. python compile      - python3 -m py_compile on changed *.py
#   8. bilingual balance   - data-en == data-zh in bilingual landing pages
#   9. twin freshness      - render-docs.py twins regenerated & staged
#
# Bypass:  git commit --no-verify        (skip ALL git hooks)
#      or  SKIP_HOOKS=1 git commit ...    (skip just these DevSecOps hooks)
#
# Tools that may be absent (shellcheck, jq, gitleaks) degrade gracefully:
# we prefer python3 (always present) for JSON/logic and only *warn* on missing
# optional linters — never hard-fail because a tool is not installed.

set -uo pipefail

if [ "${SKIP_HOOKS:-0}" = "1" ]; then
    echo "SKIP_HOOKS=1 set — skipping aclab/skills pre-commit checks."
    exit 0
fi

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

FAILED=0
pass() { echo -e "  ${GREEN}PASS${NC} $1"; }
fail() { echo -e "  ${RED}FAIL${NC} $1"; FAILED=1; }
warn() { echo -e "  ${YELLOW}WARN${NC} $1"; }
note() { echo -e "  ${BLUE}····${NC} $1"; }

echo -e "${BLUE}== aclab/skills pre-commit (DevSecOps) ==${NC}"

# Staged files (Added/Copied/Modified/Renamed — not Deleted), NUL-safe.
mapfile -d '' -t STAGED < <(git diff --cached --name-only --diff-filter=ACMR -z)
if [ "${#STAGED[@]}" -eq 0 ]; then
    echo "  (no staged files) nothing to check."
    exit 0
fi

# Added lines (with their file) for content scans: "path:content".
# Uses git diff -U0 so we only see added lines, prefixed with their file.
added_lines_with_path() {
    git diff --cached -U0 --diff-filter=ACMR -- "$@" \
    | awk '
        /^\+\+\+ b\// { f=substr($0,7); next }
        /^\+/ && !/^\+\+\+/ { print f "\t" substr($0,2) }
    '
}

# ---------------------------------------------------------------------------
# 1. Secret scan (added lines only)
# ---------------------------------------------------------------------------
echo "[1] secret scan"
# High-confidence literal credential formats + keyword=literal assignments.
HIGH_ENTROPY='AKIA[0-9A-Z]{16}|gh[pousr]_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.'
KEYWORD='(password|passwd|pwd|api[_-]?key|apikey|secret|token|bearer|private[_-]?key|access[_-]?key)[[:space:]]*[:=][[:space:]]*'
# Value forms that are NOT real secrets (refs / typed fields / placeholders / env reads).
REF_RE='[:=][[:space:]]*([$]|[$][{]|[{][{]|<|%\(|env::)'
ENVREAD_RE="[:=][[:space:]]*['\"]?(os\.environ|os\.getenv|getenv\(|process\.env|system\.getenv|deno\.env|ENV\[)"
TYPE_RE="[:=][[:space:]]*['\"]?(str|string|int|integer|bool|boolean|float|double|number|text|varchar|char|uuid|bytes|object|array|map|any|none|null|nil|true|false|optional|list|dict|set)\b"
PLACEHOLDER_RE="[:=][[:space:]]*['\"]?(changeme|change-me|change_me|your[-_a-z0-9]*|placeholder|example|sample|dummy|redacted|fixme|todo|tbd|n/a|na|set[-_]me|replace[-_]me|xxx+|<[^>]+>|[*]{3,}|[.]{3,})"
EMPTY_RE="[:=][[:space:]]*(\"\"|''|[[:space:]]*$)"

SECRET_HITS="$(added_lines_with_path . \
    | awk -F'\t' '$1 !~ /\/(evals|fixtures|__fixtures__|testdata|test-fixtures)\//' \
    | grep -viE '\.env\.(example|sample|template)' \
    | { grep -iE "($HIGH_ENTROPY)|(${KEYWORD}[^[:space:]*]+)" || true; } \
    | grep -vE 'env:|file:' \
    | grep -v 'REDACTED' \
    | grep -ivE "$REF_RE" \
    | grep -ivE "$ENVREAD_RE" \
    | grep -ivE "$TYPE_RE" \
    | grep -ivE "$PLACEHOLDER_RE" \
    | grep -ivE "$EMPTY_RE" \
    || true)"
# .env / secret-file names
ENV_FILES="$(printf '%s\n' "${STAGED[@]}" | grep -E '(^|/)\.env($|\.)' | grep -vE '\.env\.(example|sample|template)$' || true)"
SECRET_FILES="$(printf '%s\n' "${STAGED[@]}" | grep -E '(\.pem|\.key|\.p12|\.pfx|id_rsa|credentials\.json)$' || true)"
if [ -n "$SECRET_HITS" ] || [ -n "$ENV_FILES" ] || [ -n "$SECRET_FILES" ]; then
    [ -n "$SECRET_HITS" ]  && { printf '%s\n' "$SECRET_HITS" | head -5 | sed 's/^/      /'; }
    [ -n "$ENV_FILES" ]    && { echo "      .env file staged:"; printf '%s\n' "$ENV_FILES" | sed 's/^/        /'; }
    [ -n "$SECRET_FILES" ] && { echo "      secret-file pattern staged:"; printf '%s\n' "$SECRET_FILES" | sed 's/^/        /'; }
    fail "potential secret / credential material in staged changes"
else
    pass "no hardcoded secrets detected"
fi

# ---------------------------------------------------------------------------
# 2. Absolute machine-path scan (skills/** only; placeholders are fine)
# ---------------------------------------------------------------------------
echo "[2] absolute machine-path scan (skills/**)"
ABS_HITS="$(added_lines_with_path 'skills/**' \
    | awk -F'\t' '$1 !~ /\/(evals|fixtures|__fixtures__|testdata|test-fixtures)\//' \
    | grep -E '/home/[a-z_][a-z0-9_-]*/' \
    | grep -vE '/home/<[^>]+>' \
    || true)"
if [ -n "$ABS_HITS" ]; then
    printf '%s\n' "$ABS_HITS" | head -5 | sed 's/^/      /'
    fail "machine-specific /home/<user>/... path added under skills/** (use <workspace-root>)"
else
    pass "no machine-specific absolute paths under skills/**"
fi

# ---------------------------------------------------------------------------
# 3. Purged-skill denylist (do not re-introduce removed skills)
# ---------------------------------------------------------------------------
echo "[3] purged-skill denylist"
DENY='docx pdf pptx xlsx mcp-builder skill-creator webapp-testing canvas-design algorithmic-art theme-factory web-artifacts-builder slack-gif-creator internal-comms brand-guidelines claude-api doc-coauthoring jsm-query-skill user-profile-skill bi-analyst-skill mes-domain-expert-skill aws-agent-solution-architect'
DENY_HIT=""
for f in "${STAGED[@]}"; do
    # only care about a *skill folder* being added: skills/<cat>/<name>/...
    if [[ "$f" =~ ^skills/[^/]+/([^/]+)/ ]]; then
        name="${BASH_REMATCH[1]}"
        for d in $DENY; do
            [ "$name" = "$d" ] && DENY_HIT+="    $f  (purged skill: $d)"$'\n'
        done
    fi
done
if [ -n "$DENY_HIT" ]; then
    printf '%s' "$DENY_HIT"
    fail "staged path re-introduces a purged skill (see AGENTS.md / CREDITS.md)"
else
    pass "no purged skills re-introduced"
fi

# ---------------------------------------------------------------------------
# 4. JSON validity (manifest + any staged *.json)
# ---------------------------------------------------------------------------
echo "[4] JSON validity"
JSON_BAD=0
JSON_TARGETS=()
[ -f skills-manifest.json ] && JSON_TARGETS+=("skills-manifest.json")
for f in "${STAGED[@]}"; do [[ "$f" == *.json ]] && [ -f "$f" ] && JSON_TARGETS+=("$f"); done
# de-dupe
mapfile -t JSON_TARGETS < <(printf '%s\n' "${JSON_TARGETS[@]}" | awk 'NF' | sort -u)
for f in "${JSON_TARGETS[@]}"; do
    if ! python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$f" 2>/dev/null; then
        echo "      invalid JSON: $f"; JSON_BAD=1
    fi
done
if [ "$JSON_BAD" -eq 1 ]; then fail "JSON parse error"; else pass "JSON parses (${#JSON_TARGETS[@]} file(s))"; fi

# ---------------------------------------------------------------------------
# 5. Conflict markers
# ---------------------------------------------------------------------------
echo "[5] merge-conflict markers"
CONFLICT="$(added_lines_with_path . | grep -E '^[^	]+	(<{7}|={7}|>{7})( |$)' || true)"
if [ -n "$CONFLICT" ]; then
    printf '%s\n' "$CONFLICT" | head -5 | sed 's/^/      /'
    fail "leftover merge-conflict markers"
else
    pass "no conflict markers"
fi

# ---------------------------------------------------------------------------
# 6. Shell syntax (bash -n); optional shellcheck if present
# ---------------------------------------------------------------------------
echo "[6] shell syntax"
SH_BAD=0; SH_N=0
HAVE_SHELLCHECK=0; command -v shellcheck >/dev/null 2>&1 && HAVE_SHELLCHECK=1
for f in "${STAGED[@]}"; do
    case "$f" in
        *.sh|*/git-hooks/pre-commit|*/git-hooks/pre-push) [ -f "$f" ] || continue; SH_N=$((SH_N+1))
            if ! bash -n "$f" 2>/tmp/_shn.$$; then echo "      bash -n failed: $f"; sed 's/^/        /' /tmp/_shn.$$; SH_BAD=1; fi
            ;;
    esac
done
rm -f /tmp/_shn.$$
[ "$HAVE_SHELLCHECK" -eq 0 ] && [ "$SH_N" -gt 0 ] && warn "shellcheck not installed — syntax-only (bash -n) check used"
if [ "$SH_BAD" -eq 1 ]; then fail "shell syntax error"; else pass "shell syntax OK ($SH_N file(s))"; fi

# ---------------------------------------------------------------------------
# 7. Python compile
# ---------------------------------------------------------------------------
echo "[7] python compile"
PY_BAD=0; PY_N=0
for f in "${STAGED[@]}"; do
    [[ "$f" == *.py ]] || continue; [ -f "$f" ] || continue; PY_N=$((PY_N+1))
    if ! python3 -m py_compile "$f" 2>/tmp/_pyc.$$; then echo "      py_compile failed: $f"; sed 's/^/        /' /tmp/_pyc.$$; PY_BAD=1; fi
done
rm -f /tmp/_pyc.$$
if [ "$PY_BAD" -eq 1 ]; then fail "python syntax error"; else pass "python compiles ($PY_N file(s))"; fi

# ---------------------------------------------------------------------------
# 8. Bilingual HTML balance (only for staged bilingual pages)
# ---------------------------------------------------------------------------
echo "[8] bilingual HTML balance"
BILINGUAL=(methodology.html skills/spec-master/index.html skills/code-review/index.html)
BI_BAD=0; BI_N=0
for f in "${STAGED[@]}"; do
    for b in "${BILINGUAL[@]}"; do
        if [ "$f" = "$b" ] && [ -f "$f" ]; then
            BI_N=$((BI_N+1))
            en=$(grep -o 'data-en' "$f" | wc -l); zh=$(grep -o 'data-zh' "$f" | wc -l)
            if [ "$en" -ne "$zh" ]; then echo "      $f data-en=$en data-zh=$zh (unbalanced)"; BI_BAD=1; fi
        fi
    done
done
if [ "$BI_BAD" -eq 1 ]; then fail "bilingual data-en/data-zh imbalance"
elif [ "$BI_N" -eq 0 ]; then note "no bilingual page staged"; pass "n/a"
else pass "bilingual pages balanced ($BI_N)"; fi

# ---------------------------------------------------------------------------
# 9. Twin freshness — if a rendered .md is staged, its .html twin must be fresh+staged
# ---------------------------------------------------------------------------
echo "[9] markdown->HTML twin freshness"
RENDERED_MD=(docs/agentic-delivery-methodology.md docs/methodology-diagram.md docs/README.md \
             CREDITS.md AGENTS.md README.md README.zh-TW.md \
             skills/spec-master/README.md skills/code-review/README.md)
NEED_RENDER=0
for f in "${STAGED[@]}"; do
    for d in "${RENDERED_MD[@]}"; do [ "$f" = "$d" ] && NEED_RENDER=1; done
done
if [ "$NEED_RENDER" -eq 0 ]; then
    note "no rendered markdown staged"; pass "n/a"
elif [ ! -f scripts/render-docs.py ]; then
    warn "render-docs.py missing — cannot verify twins"; pass "skipped"
else
    # Snapshot current twins, render, diff, restore.
    TWIN_DIFF=""
    declare -A SAVED=()
    for d in "${RENDERED_MD[@]}"; do
        t="${d%.md}.html"; [ -f "$t" ] && SAVED["$t"]="$(cat "$t")"
    done
    python3 scripts/render-docs.py >/dev/null 2>&1 || warn "render-docs.py exited non-zero"
    for d in "${RENDERED_MD[@]}"; do
        t="${d%.md}.html"; [ -f "$t" ] || continue
        # is this twin staged with the current (freshly-rendered) content?
        staged_blob="$(git show ":$t" 2>/dev/null || true)"
        if [ "$staged_blob" != "$(cat "$t")" ]; then
            TWIN_DIFF+="    $t (out of sync — run: python3 scripts/render-docs.py && git add $t)"$'\n'
        fi
    done
    if [ -n "$TWIN_DIFF" ]; then printf '%s' "$TWIN_DIFF"; fail "HTML twin not regenerated/staged"
    else pass "HTML twins fresh and staged"; fi
fi

echo
if [ "$FAILED" -ne 0 ]; then
    echo -e "${RED}pre-commit FAILED — fix the issues above, or bypass with: git commit --no-verify${NC}"
    exit 1
fi
echo -e "${GREEN}pre-commit OK${NC}"
exit 0
